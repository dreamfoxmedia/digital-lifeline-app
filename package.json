{
  "name": "huisbeheer",
  "version": "0.1.0",
  "description": "Home Assistant client web-app, klaar voor Capacitor",
  "private": true,
  "scripts": {
    "serve": "npx http-server www -o -p 8080",
    "cap:init": "npx cap init Huisbeheer com.example.huisbeheer --web-dir=www",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/android": "^6.0.0"
  }
}
